# ─── Database ────────────────────────────────────────────────────────────────
# A PostgreSQL connection string.
#
# Recommended: Supabase (free tier available)
#   1. Go to https://supabase.com and create a new project.
#   2. In your project, go to Project Settings → Database.
#   3. Copy the "Connection string" (URI format) from the Connection Pooling section.
#   4. Replace [YOUR-PASSWORD] with your database password.
#
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── Anthropic ───────────────────────────────────────────────────────────────
# API key used to run circular analysis via Claude.
#
#   1. Go to https://console.anthropic.com and sign in.
#   2. Navigate to API Keys → Create Key.
#   3. Copy the key and paste it below.
#
ANTHROPIC_API_KEY=sk-ant-api03-...
